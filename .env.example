# ================================================================
# VARIABLES D'ENVIRONNEMENT — TeacherMada v3
# À configurer dans : Supabase → Settings → Edge Functions → Secrets
# ================================================================

# ── Supabase (auto-injectées dans Edge Functions) ──────────────
# Ces variables sont automatiquement disponibles dans les Edge Functions :
# SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_ANON_KEY
# Il n'est pas nécessaire de les redéclarer.

# ── Facebook Messenger ─────────────────────────────────────────
VERIFY_TOKEN=votre_token_verification_webhook
ADMIN_IDS=psid_admin1,psid_admin2

# ── Gemini AI ──────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── URLs ───────────────────────────────────────────────────────
# URL de base des Edge Functions (format Supabase)
EDGE_FUNCTION_BASE_URL=https://VOTRE_PROJET.supabase.co/functions/v1

# ── Nettoyage ──────────────────────────────────────────────────
CLEANUP_SECRET=un_secret_aleatoire_pour_cleanup

# ================================================================
# VARIABLES POUR LE DASHBOARD ADMIN (Render Static Site)
# À mettre dans admin/index.html (lignes SUPABASE_URL / ANON_KEY)
# ================================================================
# SUPABASE_URL = https://VOTRE_PROJET.supabase.co
# SUPABASE_ANON_KEY = eyJ...  (JAMAIS la service_role key !)
